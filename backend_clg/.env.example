# Pet Store Backend - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Port
PORT=5000

# MongoDB Connection
# For Local MongoDB:
MONGO_URI=mongodb://localhost:27017/petstore

# For MongoDB Atlas (Cloud):
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/petstore?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_characters
JWT_EXPIRY=14

# Email Configuration (Optional - for password reset feature)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_SERVICE=gmail

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Environment
NODE_ENV=development
